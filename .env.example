# Database (local dev — use docker-compose postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vajra_dev"

# Auth (Better-Auth)
BETTER_AUTH_SECRET="generate-a-random-32-char-secret-here"
BETTER_AUTH_URL="http://localhost:3000"

# App Context
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email (SMTP) — required for production, optional for dev
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-password"
SMTP_FROM="noreply@yourgym.com"

# Set to "true" to actually send emails in development mode.
# When unset or "false", emails are logged to console instead.
DEV_EMAIL_ENABLED="false"
