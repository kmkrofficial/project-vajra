# Database (local dev — use docker-compose postgres)
# For production, use Supabase connection pooler (Transaction mode):
# DATABASE_URL="postgresql://postgres.xxx:pass@aws-0-ap-south-1.pooler.supabase.com:6543/postgres"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vajra_dev"

# Auth (Better-Auth)
BETTER_AUTH_SECRET="generate-a-random-32-char-secret-here"
BETTER_AUTH_URL="http://localhost:3000"

# App Context
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email (SMTP) — required when dev.email_enabled: 1 in config.yml
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-password"
SMTP_FROM="noreply@yourgym.com"

# MSG91 (WhatsApp) — required when dev.whatsapp_enabled: 1 in config.yml
MSG91_AUTH_KEY="your-msg91-authkey"
MSG91_TEMPLATE_ID="your-whatsapp-template-id"
MSG91_INTEGRATED_NUMBER="your-msg91-whatsapp-number"
MSG91_NAMESPACE="your-msg91-namespace"

# Supabase Storage (Object Storage) — required for production
# In dev, files are stored locally in .storage-local/
SUPABASE_URL="https://xxx.supabase.co"
SUPABASE_SERVICE_KEY="your-supabase-service-role-key"
SUPABASE_STORAGE_BUCKET="assets"
